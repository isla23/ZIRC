import os
import sys
import subprocess

print("[*] SCons: Executing pre-build steps (Template Injection)...")

# Construct path to common template applier
common_dir = os.path.abspath(os.path.join('..', 'common'))
apply_script = os.path.join(common_dir, 'apply_template.py')

in_file = os.path.join('src', 'offsets.h.in')
out_file = os.path.join('src', 'offsets.h')

try:
    subprocess.check_call([sys.executable, apply_script, in_file, out_file])
except subprocess.CalledProcessError as e:
    print(f"[-] Pre-build script failed with code {e.returncode}")
    Exit(1)

print("-" * 50)

# =========================================================================
# SCONS ENVIRONMENT SETUP
# =========================================================================
env = Environment(TARGET_ARCH='amd64')

# Fetch the mode argument, default to 'release'
mode = ARGUMENTS.get('mode', 'release')

if mode == 'debug':
    # Debug mode: Disable optimization (/Od), inject macro
    env.Append(CCFLAGS=['/Od', '/EHsc', '/W3'])
    env.Append(CPPDEFINES=['ENABLE_DEBUG_CONSOLE'])
else:
    # Release mode: Maximize speed optimization (/O2)
    env.Append(CCFLAGS=['/O2', '/EHsc', '/W3'])

# Include
env.Append(CPPPATH=[
    '#lib/minhook/include',
    '#src'
])

# SRC File
sources = [
    'src/main.cpp',
    'lib/minhook/src/buffer.c',
    'lib/minhook/src/hook.c',
    'lib/minhook/src/trampoline.c',
    'lib/minhook/src/hde/hde64.c'
]

obj_dir = os.path.join('..', 'build', 'cpp', 'obj')
obj_files = []

for src in sources:
    base_name = os.path.basename(src)
    obj_name = os.path.splitext(base_name)[0]
    target_path = os.path.join(obj_dir, obj_name)
    
    # Compile directly into the build/obj directory
    obj = env.SharedObject(target=target_path, source=src)
    obj_files.append(obj)

dll_target = os.path.join('..', 'build', 'cpp', 'version')
dll = env.SharedLibrary(target=dll_target, source=obj_files)

env.Clean(dll, os.path.join('..', 'build', 'cpp'))

# Default Compile DLL
Default(dll)